{"nodes": [{"id": "developer_experience_vimmode_runtime_toggle_command_2026_06_04_document", "label": "Runtime Toggle Command for Pi Vimmode", "file_type": "document", "source_file": "docs/solutions/developer-experience/vimmode-runtime-toggle-command-2026-06-04.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "developer_experience_vimmode_runtime_toggle_command_2026_06_04_runtime_toggle_command_for_pi_vimmode", "label": "Runtime Toggle Command for Pi Vimmode", "file_type": "concept", "source_file": "docs/solutions/developer-experience/vimmode-runtime-toggle-command-2026-06-04.md", "source_location": "line 1", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "developer_experience_vimmode_runtime_toggle_command_2026_06_04_context", "label": "Context", "file_type": "concept", "source_file": "docs/solutions/developer-experience/vimmode-runtime-toggle-command-2026-06-04.md", "source_location": "line 3", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "developer_experience_vimmode_runtime_toggle_command_2026_06_04_guidance", "label": "Guidance", "file_type": "concept", "source_file": "docs/solutions/developer-experience/vimmode-runtime-toggle-command-2026-06-04.md", "source_location": "line 9", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "developer_experience_vimmode_runtime_toggle_command_2026_06_04_why_this_matters", "label": "Why This Matters", "file_type": "rationale", "source_file": "docs/solutions/developer-experience/vimmode-runtime-toggle-command-2026-06-04.md", "source_location": "line 81", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Runtime toggles are safer than configuration edits for editor-replacement extensions. They preserve Pi's extension installation, avoid restart loops, and give users a low-friction escape hatch if the modal editor becomes unusable. The important design detail is restoring the previous editor component rather than setting an arbitrary fallback. That keeps `pi-vimmode` composable with Pi defaults and with any editor component that was active before it installed."}, {"id": "developer_experience_vimmode_runtime_toggle_command_2026_06_04_when_to_apply", "label": "When to Apply", "file_type": "concept", "source_file": "docs/solutions/developer-experience/vimmode-runtime-toggle-command-2026-06-04.md", "source_location": "line 87", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "developer_experience_vimmode_runtime_toggle_command_2026_06_04_examples", "label": "Examples", "file_type": "concept", "source_file": "docs/solutions/developer-experience/vimmode-runtime-toggle-command-2026-06-04.md", "source_location": "line 94", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "developer_experience_vimmode_runtime_toggle_command_2026_06_04_related", "label": "Related", "file_type": "concept", "source_file": "docs/solutions/developer-experience/vimmode-runtime-toggle-command-2026-06-04.md", "source_location": "line 129", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "developer_experience_vimmode_runtime_toggle_command_2026_06_04_ref_test_lifecycle_test_ts", "label": "lifecycle.test.ts", "file_type": "concept", "source_file": "docs/solutions/developer-experience/vimmode-runtime-toggle-command-2026-06-04.md", "source_location": "line 123", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "developer_experience_vimmode_runtime_toggle_command_2026_06_04_ref_src_lifecycle_ts", "label": "lifecycle.ts", "file_type": "concept", "source_file": "docs/solutions/developer-experience/vimmode-runtime-toggle-command-2026-06-04.md", "source_location": "line 126", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "d