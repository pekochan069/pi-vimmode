{"nodes": [{"id": "2026_06_09_keybinding_discovery_popup_proposal_document", "label": "Proposal", "file_type": "document", "source_file": "openspec/changes/archive/2026-06-09-keybinding-discovery-popup/proposal.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "2026_06_09_keybinding_discovery_popup_proposal_why", "label": "Why", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-09-keybinding-discovery-popup/proposal.md", "source_location": "line 1", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Runtime discovery for keybindings and actions is becoming too dense for one-row status feedback. The first implementation made `:features keybindings` readable but still looked like the Ex/workbench section simply grew taller, and an overflow row such as `\u2026 8 more` was not actionable. Users need a visually distinct, prompt-local discovery surface that can reveal hidden rows without implying Vim help pager, command palette, plugin API, or runtime mapping support. ## What Changes"}, {"id": "2026_06_09_keybinding_discovery_popup_proposal_what_changes", "label": "What Changes", "file_type": "concept", "source_file": "openspec/changes/archive/2026-06-09-keybinding-discovery-popup/proposal.md", "source_location": "line 5", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "2026_06_09_keybinding_discovery_popup_proposal_capabilities", "label": "Capabilities", "file_type": "concept", "source_file": "openspec/changes/archive/2026-06-09-keybinding-discovery-popup/proposal.md", "source_location": "line 16", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "2026_06_09_keybinding_discovery_popup_proposal_new_capabilities", "label": "New Capabilities", "file_type": "concept", "source_file": "openspec/changes/archive/2026-06-09-keybinding-discovery-popup/proposal.md", "source_loc