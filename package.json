{
  "name": "pi-vimmode",
  "version": "0.0.1",
  "private": false,
  "description": "Vim mode for Pi coding agent",
  "keywords": [
    "pi",
    "pi-extension",
    "pi-package"
  ],
  "homepage": "https://github.com/pekochan069/pi-vimmode#readme",
  "bugs": {
    "url": "https://github.com/pekochan069/pi-vimmode/issues"
  },
  "license": "MIT",
  "author": "pekochan069",
  "contributors": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pekochan069/pi-vimmode.git"
  },
  "type": "module",
  "module": "index.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rolldown -c",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "bun test",
    "check-types": "tsgo --noEmit"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.76.0",
    "@earendil-works/pi-tui": "^0.76.0",
    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "bun-types": "^1.3.14",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "rolldown": "^1.0.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.76.0",
    "@earendil-works/pi-tui": "^0.76.0"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
