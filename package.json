{
  "name": "pi-vimmode",
  "version": "0.9.0",
  "private": false,
  "description": "Vim mode for Pi coding agent",
  "keywords": [
    "pi",
    "pi-extension",
    "pi-package"
  ],
  "homepage": "https://github.com/pekochan069/pi-vimmode#readme",
  "bugs": {
    "url": "https://github.com/pekochan069/pi-vimmode/issues"
  },
  "license": "MIT",
  "author": "pekochan069",
  "contributors": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pekochan069/pi-vimmode.git"
  },
  "files": [
    "index.ts",
    "src",
    "dist",
    "README.md",
    "LICENSE",
    "RELEASE.md",
    "release-notes.json",
    "docs/config.md",
    "docs/features.md",
    "docs/settings.md"
  ],
  "type": "module",
  "module": "index.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rolldown -c",
    "verify-package": "bun scripts/verify-package.ts",
    "generate:config-reference": "bun scripts/generate-config-reference.ts",
    "check:config-reference": "bun scripts/generate-config-reference.ts --check",
    "prepublish": "bun run build && bun run verify-package",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "bun test",
    "check-types": "tsc --noEmit",
    "verify": "bun run check-types && bun run lint && bun run test",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.77.0",
    "@earendil-works/pi-tui": "^0.77.0",
    "bun-types": "^1.3.14",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "rolldown": "^1.2.0",
    "typescript": "^7.0.2"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.77.0",
    "@earendil-works/pi-tui": "^0.77.0"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
